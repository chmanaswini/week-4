## Step 9: Verify Dataset Integrity

```python
import os, glob

def check_dataset(img_dir, lbl_dir):
    imgs = sorted(glob.glob(f"{img_dir}/*.png"))
    missing, errors = [], []
    for img in imgs:
        name = os.path.splitext(os.path.basename(img))[0]
        lbl  = f"{lbl_dir}/{name}.txt"
        if not os.path.exists(lbl):
            missing.append(name)
            continue
        with open(lbl) as f:
            for i, line in enumerate(f):
                parts = line.strip().split()
                if len(parts) != 5:
                    errors.append(f"{lbl}:{i} — expected 5 columns")
                elif int(parts[0]) not in [0, 1]:
                    errors.append(f"{lbl}:{i} — invalid class {parts[0]}")
    print(f"Images: {len(imgs)} | Missing labels: {len(missing)} | Errors: {len(errors)}")

check_dataset("dataset/train/images", "dataset/train/labels")
check_dataset("dataset/val/images",   "dataset/val/labels")
```

